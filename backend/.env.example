# Copy to .env and fill in
GEMINI_API_KEY=API_KEY_HERE
GEMINI_MODEL=gemini-3.5-flash
PORT=4000

# --- Live data connector (Phase 3) ---
# Leave LIVE_DATA_PROTOCOL unset (or "mock") for local dev with built-in mock data.
# LIVE_DATA_PROTOCOL=rest | websocket | mqtt | opcua | modbus

# rest:
# LIVE_DATA_REST_BASE_URL=https://plant-gateway.example.com/api
# LIVE_DATA_TIMEOUT_MS=5000

# websocket:
# LIVE_DATA_WS_URL=wss://plant-gateway.example.com/live

# mqtt:
# LIVE_DATA_MQTT_BROKER_URL=mqtt://plant-broker.example.com:1883
# LIVE_DATA_MQTT_SCADA_PREFIX=plant/scada
# LIVE_DATA_MQTT_PERMITS_PREFIX=plant/permits

# opcua (NOT tested in this sandbox — see src/connectors/opcUaConnector.ts):
# LIVE_DATA_OPCUA_ENDPOINT=opc.tcp://plant-server:4840
# LIVE_DATA_OPCUA_NODE_MAP={"Zone4":"ns=2;s=Zone4.GasPPM"}

# modbus (NOT tested in this sandbox — see src/connectors/modbusConnector.ts):
# LIVE_DATA_MODBUS_HOST=192.168.1.50
# LIVE_DATA_MODBUS_PORT=502
# LIVE_DATA_MODBUS_UNIT_MAP={"Zone4":1}

# Optional: incident/equipment/maintenance records API (falls back to mock if unset)
# PLANT_RECORDS_API_BASE_URL=https://plant-records.example.com/api
