# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────
DATABASE_URL="postgresql://YOUR_USERNAME:YOUR_PASSWORD@localhost:5432/YOUR_DATABASE?schema=public"

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=debug
